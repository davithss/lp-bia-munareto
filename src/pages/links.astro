---
import Layout from "../layouts/Layout.astro";

const primaryLinks = [
  {
    label: "Suma por 30 dias comigo",
    href: "https://biamunareto.naracode.com.br/caverna-b?utm_source=bio&utm_campaign=caverna&fbclid=PAVERFWARvHupleHRuA2FlbQIxMABzcnRjBmFwcF9pZA8xMjQwMjQ1NzQyODc0MTQAAadTg9wPyIJQkvvGWxJSlgr7X4U_jGyU94SuQXXeGsgMC7y69GBYhATC8VB3cA_aem_AEOnXjZpoQ_GtFnvQ4MQdQ",
    note: "Uma experiência de imersão com Bia Munareto",
    image: "/images/bio-link-1.jpg"
  },
  {
    label: "Seja minha Cliente",
    href: "https://www.biamunareto.com.br/",
    note: "Melhore sua vida pessoal, espiritual, amorosa e profissional na Jornada do Autoamor",
    image: "/images/bio-link-2.jpg"
  },
  {
    label: "Seja minha Mentoranda",
    href: "https://docs.google.com/forms/d/e/1FAIpQLSd0Vzp0fnw_tW6NiEfCIhh1yfXNBFjou_zo6a71pCNSPigtqg/viewform",
    note: "Seguro na sua mão e acompanho seu desenvolvimento semanalmente",
    image: "/images/bio-link-3.jpg"
  },
  {
    label: "Compre o Livro da Jornada do Autoamor e receba em casa",
    href: "https://biamunaretto.com.br/livro-a-jornada-do-autoamor-2/",
    note: "O livro físico da Jornada entregue no seu endereço",
    image: "/images/bio-link-4.jpg"
  },
  {
    label: "Contato profissional",
    href: "https://wa.me/message/VOVQ7D64JUXRC1",
    note: "Dúvidas, contratação para palestras e eventos",
    image: "/images/bio-link-5.jpg"
  }
];
---

<Layout
  title="Links da Bia Munareto"
  description="Links oficiais da Bia Munareto: Caverna, Jornada do Autoamor, mentoria, livro e contato profissional."
  canonicalPath="/links"
>
  <main class="bio-links-page">
    <section class="bio-shell" aria-label="Links oficiais da Bia Munareto">
      <div class="bio-frame">
        <header class="bio-hero">
          <a class="bio-signature" href="/" aria-label="Voltar para a página inicial">Bia Munareto</a>
          <p class="bio-kicker">Psicologia · Corpo · Espiritualidade</p>
          <div class="bio-portrait-wrap">
            <img src="/images/bia-links-profile.jpg" alt="Bia Munareto" class="bio-main-photo" />
          </div>
          <p class="bio-subtitle">Escolha seu próximo passo comigo.</p>
        </header>

        <div class="bio-links-list">
          {primaryLinks.map((link, index) => (
            <a class={`bio-link ${index === 0 ? "bio-link-featured" : ""}`} href={link.href} target="_blank" rel="noopener noreferrer">
              <span class="bio-link-media">
                <img src={link.image} alt="" class="bio-link-thumb" />
              </span>
              <span class="bio-link-copy">
                <span class="bio-link-index">0{index + 1}</span>
                <strong>{link.label}</strong>
                <em>{link.note}</em>
              </span>
              <span class="bio-link-arrow">→</span>
            </a>
          ))}
        </div>

        <footer class="bio-footer">
          <p>Site oficial · Jornada do Autoamor</p>
          <a href="/">www.biamunareto.com.br</a>
        </footer>
      </div>
    </section>
  </main>

  <style>
    :global(body){background:#fff;color:#251817;}
    :global(.sticky-cta){display:none!important;}
    .bio-links-page{min-height:100vh;background:#fff;overflow:hidden;}
    .bio-shell{min-height:100vh;display:grid;place-items:start center;padding:20px 16px 30px;position:relative;background:#fff;}
    .bio-frame{width:min(430px,100%);position:relative;padding:18px 0 26px;background:#fff;}
    .bio-hero{position:relative;text-align:center;}
    .bio-signature{display:inline-block;border:0;margin:0 auto 9px;color:#211615;font-family:var(--serif);font-size:clamp(42px,12vw,58px);line-height:.9;font-style:italic;font-weight:500;letter-spacing:-.055em;text-decoration:none;}
    .bio-kicker{margin:0 0 17px;color:#8d7771;font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:.2em;}
    .bio-portrait-wrap{width:min(318px,82vw);aspect-ratio:4/5;margin:0 auto 18px;overflow:hidden;background:#f6f0ed;border-radius:2px;box-shadow:0 18px 48px rgba(37,24,23,.13);}
    .bio-main-photo{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;}
    .bio-subtitle{max-width:310px;margin:0 auto;color:#685653;font-size:14px;line-height:1.45;}
    .bio-links-list{position:relative;display:grid;gap:11px;margin-top:21px;}
    .bio-link{display:grid;grid-template-columns:92px 1fr 18px;gap:12px;align-items:center;min-height:104px;padding:7px 13px 7px 7px;border-radius:0;border:1px solid #eadfda;background:#fff;color:#251817;text-decoration:none;box-shadow:none;transition:transform .2s ease,border-color .2s ease,background .2s ease;}
    .bio-link:hover{transform:translateY(-1px);background:#fffaf7;border-color:#d7c5bd;border-bottom-color:#d7c5bd;}
    .bio-link-featured{background:#fff;border-color:#eadfda;}
    .bio-link-media{display:block;width:92px;height:90px;border-radius:0;overflow:hidden;border:0;background:#f6f0ed;}
    .bio-link-thumb{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;}
    .bio-link-copy{display:grid;gap:3px;text-align:left;align-content:center;}
    .bio-link-index{color:#b11226;font-size:9px;font-weight:950;letter-spacing:.16em;text-transform:uppercase;}
    .bio-link-copy strong{color:#251817;font-size:14px;line-height:1.12;font-weight:900;letter-spacing:-.014em;}
    .bio-link-copy em{color:#7a6661;font-style:normal;font-size:10.8px;line-height:1.24;}
    .bio-link-arrow{color:#b11226;font-size:18px;line-height:1;font-weight:900;}
    .bio-footer{position:relative;margin-top:22px;text-align:center;color:#8d7771;font-size:12px;}
    .bio-footer p{margin:0 0 2px;}
    .bio-footer a{color:#b11226;border:0;font-weight:800;}
    @media(max-width:420px){.bio-shell{padding:16px 14px 26px}.bio-frame{padding-top:10px}.bio-signature{font-size:48px}.bio-portrait-wrap{width:82vw;margin-bottom:16px}.bio-link{grid-template-columns:82px 1fr 16px;min-height:94px;gap:10px;padding:6px 10px 6px 6px}.bio-link-media{width:82px;height:82px}.bio-link-copy strong{font-size:13px}.bio-link-copy em{font-size:10px}.bio-link-index{font-size:8.5px}}
  </style>
</Layout>
