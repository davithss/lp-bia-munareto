---
import Layout from "../layouts/Layout.astro";

const primaryLinks = [
  {
    label: "Suma por 30 dias comigo",
    href: "https://biamunareto.naracode.com.br/caverna-b?utm_source=bio&utm_campaign=caverna&fbclid=PAVERFWARvHupleHRuA2FlbQIxMABzcnRjBmFwcF9pZA8xMjQwMjQ1NzQyODc0MTQAAadTg9wPyIJQkvvGWxJSlgr7X4U_jGyU94SuQXXeGsgMC7y69GBYhATC8VB3cA_aem_AEOnXjZpoQ_GtFnvQ4MQdQ",
    note: "Uma experiência de imersão com Bia Munareto",
    image: "/images/bio-link-1.jpg"
  },
  {
    label: "Seja minha Cliente",
    href: "https://www.biamunareto.com.br/",
    note: "Jornada do Autoamor",
    image: "/images/bio-link-2.jpg"
  },
  {
    label: "Seja minha Mentoranda",
    href: "https://docs.google.com/forms/d/e/1FAIpQLSd0Vzp0fnw_tW6NiEfCIhh1yfXNBFjou_zo6a71pCNSPigtqg/viewform",
    note: "Acompanhamento semanal",
    image: "/images/bio-link-3.jpg"
  },
  {
    label: "Compre o Livro da Jornada",
    href: "https://biamunaretto.com.br/livro-a-jornada-do-autoamor-2/",
    note: "Receba em casa",
    image: "/images/bio-link-4.jpg"
  },
  {
    label: "Contato profissional",
    href: "https://wa.me/message/VOVQ7D64JUXRC1",
    note: "Dúvidas, palestras e eventos",
    image: "/images/bio-link-5.jpg"
  }
];
---

<Layout
  title="Links da Bia Munareto"
  description="Links oficiais da Bia Munareto: Caverna, Jornada do Autoamor, mentoria, livro e contato profissional."
  canonicalPath="/links"
>
  <main class="links-page" aria-label="Links oficiais da Bia Munareto">
    <section class="links-stack">
      <div class="links-brand" aria-label="Bia Munareto">
        <img src="/images/logo-bia-white.png" alt="Bia Munareto" />
      </div>

      {primaryLinks.map((link, index) => (
        <a class={`link-card link-card-${index + 1}`} href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
          <img src={link.image} alt="" class="link-card-image" loading="eager" />
          <span class="link-card-overlay"></span>
          <span class="link-card-border"></span>
          <span class="link-card-content">
            <strong>{link.label}</strong>
            <em>{link.note}</em>
          </span>
          <span class="link-card-arrow" aria-hidden="true">›</span>
        </a>
      ))}
    </section>
  </main>

  <style>
    :global(body){background:#fff;color:#251817;}
    :global(.sticky-cta){display:none!important;}
    .links-page{min-height:100vh;background:#fff;padding:34px 28px 42px;display:flex;justify-content:center;align-items:flex-start;}
    .links-stack{width:min(534px,100%);display:grid;gap:20px;}
    .links-brand{width:min(310px,74%);margin:0 auto 4px;padding:15px 24px 17px;border-radius:999px;background:linear-gradient(135deg,#5a1118 0%,#8c2d37 100%);box-shadow:0 14px 36px rgba(97,16,23,.18);}
    .links-brand img{display:block;width:100%;height:auto;}
    .link-card{position:relative;min-height:220px;display:flex;align-items:flex-end;overflow:hidden;border-radius:30px;color:#fff;text-decoration:none;background:#e9ded8;box-shadow:0 10px 30px rgba(43,25,21,.16);isolation:isolate;transition:transform .22s ease,box-shadow .22s ease;}
    .link-card:hover{transform:translateY(-2px);box-shadow:0 16px 42px rgba(43,25,21,.22);border-bottom-color:transparent;}
    .link-card-image{position:absolute;inset:-24px 0;width:100%;height:calc(100% + 56px);object-fit:cover;object-position:center var(--face-position,32%);z-index:-2;}
    .link-card-1{--face-position:24%;}
    .link-card-2{--face-position:38%;}
    .link-card-3{--face-position:31%;}
    .link-card-4{--face-position:36%;}
    .link-card-5{--face-position:28%;}
    .link-card-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.04) 0%,rgba(0,0,0,.12) 42%,rgba(0,0,0,.64) 100%);z-index:-1;}
    .link-card-border{position:absolute;inset:14px;border:1px solid rgba(255,255,255,.42);border-radius:23px;pointer-events:none;}
    .link-card-content{display:grid;gap:9px;max-width:calc(100% - 104px);padding:0 88px 41px 32px;text-shadow:0 2px 18px rgba(0,0,0,.34);}
    .link-card-content strong{font-family:var(--serif);font-size:clamp(29px,7vw,38px);font-style:italic;font-weight:500;line-height:.98;letter-spacing:-.04em;}
    .link-card-content em{font-style:normal;font-size:15px;line-height:1.2;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.88);}
    .link-card-arrow{position:absolute;right:28px;bottom:34px;width:40px;height:40px;border-radius:50%;display:grid;place-items:center;background:rgba(255,255,255,.9);color:#611017;font-size:32px;line-height:1;font-weight:800;box-shadow:0 8px 24px rgba(0,0,0,.14);}
    @media(max-width:520px){.links-page{padding:28px 22px 34px}.links-stack{gap:18px}.links-brand{width:min(280px,82%);padding:13px 22px 15px;margin-bottom:2px}.link-card{min-height:190px;border-radius:26px}.link-card-border{inset:12px;border-radius:20px}.link-card-content{padding:0 76px 32px 26px;max-width:calc(100% - 80px)}.link-card-content strong{font-size:30px}.link-card-content em{font-size:12px}.link-card-arrow{right:24px;bottom:28px;width:36px;height:36px;font-size:28px}}
  </style>
</Layout>
