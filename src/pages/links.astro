---
import Layout from "../layouts/Layout.astro";

const primaryLinks = [
  {
    label: "Suma por 30 dias comigo",
    href: "https://biamunareto.naracode.com.br/caverna-b?utm_source=bio&utm_campaign=caverna&fbclid=PAVERFWARvHupleHRuA2FlbQIxMABzcnRjBmFwcF9pZA8xMjQwMjQ1NzQyODc0MTQAAadTg9wPyIJQkvvGWxJSlgr7X4U_jGyU94SuQXXeGsgMC7y69GBYhATC8VB3cA_aem_AEOnXjZpoQ_GtFnvQ4MQdQ",
    note: "Uma experiência de imersão com Bia Munareto",
    image: "/images/bio-link-1.jpg"
  },
  {
    label: "Seja minha Cliente",
    href: "https://www.biamunareto.com.br/",
    note: "Melhore sua vida pessoal, espiritual, amorosa e profissional na Jornada do Autoamor",
    image: "/images/bio-link-2.jpg"
  },
  {
    label: "Seja minha Mentoranda",
    href: "https://docs.google.com/forms/d/e/1FAIpQLSd0Vzp0fnw_tW6NiEfCIhh1yfXNBFjou_zo6a71pCNSPigtqg/viewform",
    note: "Seguro na sua mão e acompanho seu desenvolvimento semanalmente",
    image: "/images/bio-link-3.jpg"
  },
  {
    label: "Compre o Livro da Jornada do Autoamor e receba em casa",
    href: "https://biamunaretto.com.br/livro-a-jornada-do-autoamor-2/",
    note: "O livro físico da Jornada entregue no seu endereço",
    image: "/images/bio-link-4.jpg"
  },
  {
    label: "Contato profissional",
    href: "https://wa.me/message/VOVQ7D64JUXRC1",
    note: "Dúvidas, contratação para palestras e eventos",
    image: "/images/bio-link-5.jpg"
  }
];
---

<Layout
  title="Links da Bia Munareto"
  description="Links oficiais da Bia Munareto: Caverna, Jornada do Autoamor, mentoria, livro e contato profissional."
  canonicalPath="/links"
>
  <main class="bio-links-page">
    <section class="bio-shell" aria-label="Links oficiais da Bia Munareto">
      <div class="bio-frame">
        <div class="bio-bg-photo" aria-hidden="true"></div>
        <div class="bio-glow bio-glow-one"></div>
        <div class="bio-glow bio-glow-two"></div>

        <header class="bio-hero">
          <a class="bio-logo" href="/" aria-label="Voltar para a página inicial">
            <img src="/images/logo-bia-white.png" alt="Bia Munareto" />
          </a>

          <div class="bio-editorial">
            <img src="/images/bio-link-2.jpg" alt="Bia Munareto" class="bio-main-photo" />
            <div class="bio-polaroid bio-polaroid-left">
              <img src="/images/bio-link-3.jpg" alt="Bia Munareto" />
            </div>
            <div class="bio-polaroid bio-polaroid-right">
              <img src="/images/bio-link-4.jpg" alt="Bia Munareto" />
            </div>
            <span class="bio-seal">Autoamor</span>
          </div>

          <p class="bio-kicker">Psicologia · Corpo · Espiritualidade</p>
          <h1>Bia Munareto</h1>
          <p class="bio-subtitle">Escolha seu próximo passo comigo.</p>
        </header>

        <div class="bio-links-list">
          {primaryLinks.map((link, index) => (
            <a class={`bio-link ${index === 0 ? "bio-link-featured" : ""}`} href={link.href} target="_blank" rel="noopener noreferrer">
              <img src={link.image} alt="" class="bio-link-thumb" />
              <span class="bio-link-copy">
                <strong>{link.label}</strong>
                <em>{link.note}</em>
              </span>
              <span class="bio-link-arrow">→</span>
            </a>
          ))}
        </div>

        <footer class="bio-footer">
          <p>Site oficial · Jornada do Autoamor</p>
          <a href="/">www.biamunareto.com.br</a>
        </footer>
      </div>
    </section>
  </main>

  <style>
    :global(body){background:#170608;color:#fff;}
    :global(.sticky-cta){display:none!important;}
    .bio-links-page{min-height:100vh;background:#170608;overflow:hidden;}
    .bio-shell{min-height:100vh;display:grid;place-items:center;padding:18px;position:relative;background:radial-gradient(circle at 50% -10%,rgba(231,177,94,.18),transparent 38%),linear-gradient(180deg,#2a080d 0%,#120406 100%);}
    .bio-frame{width:min(430px,100%);min-height:calc(100vh - 36px);position:relative;overflow:hidden;border-radius:36px;padding:22px 18px 24px;border:1px solid rgba(255,238,210,.22);background:linear-gradient(180deg,rgba(60,14,19,.82),rgba(17,5,7,.96));box-shadow:0 30px 100px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.12);}
    .bio-bg-photo{position:absolute;inset:0;background:linear-gradient(180deg,rgba(29,6,9,.3),rgba(29,6,9,.95) 50%,#110507 100%),url('/images/bio-link-5.jpg') center top/cover;opacity:.28;filter:saturate(.9);}
    .bio-glow{position:absolute;border-radius:999px;filter:blur(2px);pointer-events:none;}
    .bio-glow-one{width:240px;height:240px;right:-110px;top:-80px;background:radial-gradient(circle,rgba(231,177,94,.28),transparent 66%);}
    .bio-glow-two{width:280px;height:280px;left:-145px;top:220px;background:radial-gradient(circle,rgba(177,18,38,.42),transparent 68%);}
    .bio-hero{position:relative;z-index:1;text-align:center;}
    .bio-logo{display:inline-flex;border:0;margin-bottom:14px;}
    .bio-logo img{width:150px;height:auto;object-fit:contain;}
    .bio-editorial{position:relative;width:100%;height:330px;margin:0 auto 18px;display:grid;place-items:center;}
    .bio-editorial:before{content:"";position:absolute;width:230px;height:292px;border-radius:999px;background:linear-gradient(180deg,rgba(255,239,210,.32),rgba(177,18,38,.22));transform:rotate(8deg);}
    .bio-main-photo{position:relative;z-index:3;width:220px;height:300px;object-fit:cover;object-position:center top;border-radius:999px 999px 30px 30px;border:5px solid rgba(255,244,226,.94);box-shadow:0 30px 80px rgba(0,0,0,.5);}
    .bio-polaroid{position:absolute;z-index:4;width:92px;padding:5px 5px 18px;border-radius:16px;background:#fff4e2;box-shadow:0 18px 46px rgba(0,0,0,.4);}
    .bio-polaroid img{width:100%;height:112px;object-fit:cover;object-position:center top;border-radius:11px;display:block;}
    .bio-polaroid-left{left:4px;bottom:34px;transform:rotate(-10deg);}
    .bio-polaroid-right{right:0;top:44px;transform:rotate(9deg);}
    .bio-seal{position:absolute;z-index:5;right:44px;bottom:18px;width:82px;height:82px;display:grid;place-items:center;border-radius:50%;background:linear-gradient(135deg,#e7b15e,#b11226);color:#fff7ef;font-family:var(--serif);font-style:italic;font-size:18px;box-shadow:0 16px 42px rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.45);}
    .bio-kicker{margin:0 0 8px;color:#e7b15e;font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:.18em;}
    .bio-hero h1{margin:0;color:#fff;font-family:var(--serif);font-size:clamp(48px,13vw,66px);line-height:.86;font-style:italic;letter-spacing:-.045em;text-shadow:0 16px 44px rgba(0,0,0,.55);}
    .bio-subtitle{max-width:310px;margin:14px auto 0;color:rgba(255,247,239,.82);font-size:15px;line-height:1.55;}
    .bio-links-list{position:relative;z-index:2;display:grid;gap:11px;margin-top:18px;}
    .bio-link{display:grid;grid-template-columns:56px 1fr 24px;gap:12px;align-items:center;padding:10px 12px;border-radius:999px;border:1px solid rgba(255,244,226,.46);background:rgba(255,244,226,.92);color:#3b0b10;text-decoration:none;box-shadow:0 16px 44px rgba(0,0,0,.2);transition:transform .2s ease,box-shadow .2s ease,background .2s ease;}
    .bio-link:hover{transform:translateY(-2px);box-shadow:0 20px 52px rgba(0,0,0,.28);background:#fff8ec;border-bottom-color:rgba(255,244,226,.46);}
    .bio-link-featured{background:linear-gradient(135deg,#fff7ea,#e7b15e);border-color:rgba(255,255,255,.75);}
    .bio-link-thumb{width:52px;height:52px;border-radius:50%;object-fit:cover;object-position:center top;border:2px solid rgba(177,18,38,.2);}
    .bio-link-copy{display:grid;gap:2px;text-align:left;}
    .bio-link-copy strong{color:#3b0b10;font-size:14px;line-height:1.16;font-weight:950;letter-spacing:-.015em;}
    .bio-link-copy em{color:rgba(59,11,16,.68);font-style:normal;font-size:11px;line-height:1.28;}
    .bio-link-arrow{color:#b11226;font-size:20px;line-height:1;font-weight:900;}
    .bio-footer{position:relative;z-index:2;margin-top:22px;text-align:center;color:rgba(255,247,239,.62);font-size:12px;}
    .bio-footer p{margin:0 0 2px;}
    .bio-footer a{color:#e7b15e;border:0;font-weight:800;}
    @media(max-width:420px){.bio-shell{padding:0}.bio-frame{min-height:100vh;border-radius:0;border-left:0;border-right:0;padding:20px 14px 22px}.bio-logo img{width:136px}.bio-editorial{height:304px}.bio-main-photo{width:198px;height:276px}.bio-polaroid{width:80px}.bio-polaroid img{height:96px}.bio-seal{width:72px;height:72px;font-size:16px;right:34px}.bio-link{grid-template-columns:50px 1fr 20px;padding:9px 10px}.bio-link-thumb{width:48px;height:48px}.bio-link-copy strong{font-size:13px}.bio-link-copy em{font-size:10.5px}}
  </style>
</Layout>
