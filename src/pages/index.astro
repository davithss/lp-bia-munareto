---
import Layout from "../layouts/Layout.astro";
import content from "../data/content.json";

const { brand } = content;

const ctaAnchor = "#precos";

const proofItems = [
  "+14 mil mulheres nos últimos 9 anos",
  "9 anos de atuação profissional",
  "+500 livros vendidos",
  "Psicóloga, mãe, esposa e mulher tântrica",
  "Fundadora do Instituto Autoamor"
];

const larSteps = [
  {
    letter: "L",
    title: "Libertar",
    text: [
      "O primeiro passo é a purificação da mente e do coração.",
      "Limpar o que foi acumulado, programado e instalado antes mesmo da consciência. Soltar padrões herdados, crenças que aprisionam e contrações que impedem o fluxo da vida.",
      "Sem esse esvaziamento, não há espaço para o novo nascer. A mulher que pula essa etapa vai construir sobre o mesmo chão — e os velhos padrões voltam, sempre."
    ]
  },
  {
    letter: "A",
    title: "Assumir",
    text: [
      "O segundo passo é a nutrição e edificação da nova identidade.",
      "Assumir a liderança da própria vida e se vestir da própria essência. Reconhecer, nutrir e encarnar quem você é de verdade — não a partir do que os outros esperam, mas do que a alma reconhece como verdadeiro.",
      "Não é descobrir quem você é. É reconhecer o que sempre esteve lá — e que foi encoberto. O retorno para a essência."
    ]
  },
  {
    letter: "R",
    title: "Realizar",
    text: [
      "O terceiro passo é elevar, embelezar e receber.",
      "Com a mente purificada e a identidade construída, a mulher entra no campo de cocriação: o espaço onde o interno se torna externo. Nos relacionamentos. No corpo. Na forma como o mundo responde.",
      "A transformação para de ser interna e passa a ser visível."
    ]
  }
];

const mirrorQuotes = [
  "Sou boa para todo mundo menos para mim mesma.",
  "Trabalho muito, me doo muito. Mas sinto que falta algo.",
  "Faço terapia, cursos, meditação. Tenho consciência, mas continuo andando em círculos e repetindo as mesmas histórias. Tô cansada!",
  "Já sei o que preciso fazer, mas não faço. Parece que tem algo que me impede.",
  "Sei a importância de me priorizar, mas me sinto culpada quando faço algo para mim.",
  "Quero me aprofundar na espiritualidade."
];


const testimonialsOne = [];
const officialTestimonialsOne = [
  "/images/dep/comdep-1.jpg",
  "/images/dep/bia-secao/site-sequencia-2.jpg",
  "/images/dep/bia-secao/site-sequencia-3.jpg",
  "/images/dep/bia-secao/site-sequencia-4.jpg",
  "/images/dep/bia-secao/site-sequencia-5.jpg",
  "/images/dep/bia-secao/site-sequencia-6.jpg"
];

const officialTestimonialsTwo = [
  "/images/dep/comdep-5.jpg",
  "/images/dep/comdep-6.jpg",
  "/images/dep/comdep-2.jpg"
];


const basicItems = [
  "Boas-vindas e orientações para navegar a jornada completa",
  "7 Camadas para chegar na raiz",
  "7 dias de prática para acelerar seus resultados desde o início",
  "Gestão de Tempo e Autoamor",
  "Alma — espiritualidade na prática: ervas, cristais, pêndulos, sonhos e oráculos",
  "Quebra de Correntes e Curas Familiares",
  "Mantras e meditações guiadas",
  "Encontros semanais ao vivo com Bia Munareto",
  "Master Classes ao vivo"
];

const advancedItems = [
  "A Mulher Tântrica — identidade tântrica, corpo como portal e prazer sagrado",
  "Acelerador de Resultados — práticas de manifestação",
  "21 dias de meditação tântrica ao vivo com Bia Munareto",
  "Ritual diário para elevar sua frequência",
  "Maturidade Emocional",
  "Dinheiro, Poder e Independência",
  "Autoestima e Sexualidade",
  "Relacionamentos Amorosos",
  "Propósito e Manifestação",
  "8 Meditações Tântricas Exclusivas",
  "Mapa da Individualidade: Astrologia, Numerologia e Desenho Humano"
];

const testimonialsTwo = [];

const forYou = [
  "Você já se reconheceu nos seus padrões, mas continua repetindo.",
  "Você tentou cursos e processos antes, e sabe que precisa de algo com mais suporte e constância.",
  "Você sente que a transformação que quer pede mais do que conteúdo avulso.",
  "Você quer um espaço que exista toda semana.",
  "Você já tentou sozinha e não conseguiu.",
  "Você está pronta para se dar os 12 meses que a mudança real precisa."
];

const notForYou = [
  "Você está buscando uma solução rápida ou um conteúdo que resolve em um fim de semana.",
  "Você não está disposta a se comprometer com uma jornada de transformação real.",
  "Você prefere continuar adoecida."
];

const monthlyIncludes = [
  ...basicItems,
  "WhatsApp Irmãs de Alma",
  "Novos conteúdos e práticas liberados mensalmente",
  "Caderno Terapêutico",
  "Planilha Financeira",
  "Ferramentas que facilitam a vida da mulher moderna"
];

const annualIncludes = [
  ...monthlyIncludes,
  ...advancedItems,
  "TRIX Inspira — IA treinada por Bia disponível 24h por dia",
  "Direcionamento para utilização de ervas e práticas espirituais"
];

const premiumIncludes = [
  "Experiência presencial da Jornada do Autoamor",
  "12 meses de encontros presenciais",
  "1 encontro presencial por mês em Aracaju/SE",
  "Vivência mais profunda, íntima e acompanhada com Bia",
  "Entrada por lista de espera para a próxima turma Premium"
];

const pricingFeatures = [
  ["Acesso à Comunidade Jornada do Autoamor", true, true, true],
  ["Aulas, práticas, meditações e caderno terapêutico", true, true, true],
  ["Encontros semanais ao vivo com Bia", true, true, true],
  ["WhatsApp Irmãs de Alma", true, true, true],
  ["Aprofundamentos e práticas avançadas", false, true, true],
  ["TRIX Inspira — IA treinada por Bia", false, true, false],
  ["Direcionamento com ervas e práticas espirituais", false, true, false],
  ["12 encontros presenciais em Aracaju/SE", false, false, true]
];


const faqs = [
  ["Não vou ter tempo para acompanhar tudo.", "A Comunidade foi feita para a rotina real. Os módulos ficam disponíveis — você acessa quando pode. O que muda é que você para de estar sozinha no processo. Mesmo nas semanas em que mal consegue respirar, o WhatsApp existe. A live fica gravada. A jornada não para por você — ela espera."],
  ["Já fiz muita coisa e não mudou.", "O que você fez antes provavelmente não tinha os três elementos juntos: método + ambiente + espiritualidade. Qualquer um dos três separado funciona até certo ponto. Os três juntos chegam onde nenhum chegou sozinho. A crença 'mais uma coisa não vai ser diferente' é exatamente o padrão que a Comunidade trabalha."],
  ["Não sei se sou espiritual o suficiente.", "A Comunidade integra — não exige. Você começa de onde está. A Bia tem formação clínica robusta, e o sagrado aqui não é dogma: é prática. Se você tem resistência à espiritualidade, a Comunidade vai trabalhar com você nessa resistência também — porque ela costuma vir do mesmo lugar que o padrão de se anular."],
  ["E se eu não me encaixar no grupo?", "O WhatsApp Irmãs de Alma é o único lugar onde você não precisa explicar por que está cansada de ser forte. As mulheres que chegam aqui chegam com o mesmo padrão, a mesma história, a mesma fome de ser compreendida. Você vai se reconhecer."],
  ["Está caro.", "Compare com o que você já gastou em cursos avulsos, sessões de terapia ou processos que não tinham estrutura para sustentar a mudança. O que custa mais é continuar tentando sozinha e chegando no mesmo lugar. Quanto vale o tempo da vida que você tem perdido repetindo os mesmos ciclos?"],
  ["E se eu começar e não gostar?", "Você pode começar pelo plano mensal e sentir a Comunidade antes de se comprometer com o ano. Mas as mulheres que mais se transformam são as que se deram os 12 meses que o método precisa — porque é o tempo real para a mudança fazer raiz, não só acontecer."],
  ["Já comprei um curso antes e nunca terminei.", "A Comunidade não é um curso. É um espaço que existe toda semana — com ou sem impulso inicial, com ou sem hype. A estrutura foi feita para a mulher que já sabe que não sustenta sozinha. Você não precisa de força de vontade infinita. Você precisa de um lugar que não some."]
];
---

<Layout
  title="Comunidade Jornada do Autoamor — Bia Munareto"
  description="Acompanhamento de 12 meses para mulheres que querem resgatar o autoamor, a autoestima e a autoconfiança com psicologia, tantra, constelação familiar e espiritualidade."
>
  <main class="sales-page">
    <header class="sales-nav">
      <a href="/" class="brand brand-logo"><img src="/images/logo-bia-white.png" alt={brand.name} /></a>
      <nav>
        <a href="#metodo">Método LAR</a>
        <a href="#comunidade">Comunidade</a>
        <a href="#precos">Planos</a>
      </nav>
    </header>

    <section class="hero-sales">
      <div class="hero-overlay"></div>
      <div class="wrap hero-grid">
        <div class="hero-copy">
          <div class="hero-badge">Comunidade Jornada do Autoamor</div>
          <p class="subbrand">Bia Munareto · Psicologia, Tantra, Constelação Familiar e Espiritualidade</p>
          <h2>Torne-se a mulher mais feliz e realizada que você conhece resgatando seu Autoamor.</h2>
          <p class="hero-manifesto">Pare de chamar de destino a vida que você ainda não assumiu a liderança.</p>
          <div class="hero-panel">
            <p class="lead">A Comunidade Jornada do Autoamor é um espaço seguro para mulheres que precisam se desprender de dores e resgatar a alegria de viver.</p>
            <p class="lead emphasis">Um acompanhamento de 12 meses para <mark>construir a mulher que você deseja se tornar</mark>.</p>
            <div class="hero-tags">
              <span>Encontros semanais</span>
              <span>Imersões</span>
              <span>Meditações</span>
              <span>Rituais de manifestação</span>
              <span>Irmandade</span>
              <span>Aplicativo</span>
              <span>Aulas</span>
              <span>Orações</span>
              <span>Ferramentas para o dia a dia</span>
            </div>
          </div>
          <div class="hero-actions">
            <a href={ctaAnchor} class="btn primary">Quero entrar na Comunidade</a>
            <p class="micro">Menos de R$ 2,00 por dia · Venda segura</p>
          </div>
        </div>
        <figure class="hero-photo">
          <img src="/images/hero.jpg" alt="Bia Munareto" loading="eager" />
        </figure>
      </div>
    </section>

    <section class="proof-bar">
      <div class="wrap proof-grid">
        {proofItems.map((item) => <div><strong>{item}</strong></div>)}
      </div>
    </section>

    <section class="section lar-section" id="metodo">
      <div class="wrap center narrow">
        <p class="kicker">Método LAR</p>
        <h2>A jornada segue o Método LAR</h2>
        <p class="lead">A geometria de transformação que a Bia desenvolveu em 9 anos de trabalho clínico, vivência pessoal e em grupo.</p>
      </div>
      <div class="wrap lar-grid">
        {larSteps.map((step) => (
          <article class="lar-card">
            <span>{step.letter}</span>
            <h3>{step.title}</h3>
            {step.text.map((p) => <p>{p}</p>)}
          </article>
        ))}
      </div>
      <div class="wrap lar-note">
        <strong>A jornada completa precisa das três etapas — e a Comunidade te conduz por elas.</strong>
      </div>
    </section>

    <section class="section post-lar-testimonials" aria-label="Depoimentos de alunas">
      <div class="testimonial-carousel" data-carousel>
        <button class="testimonial-arrow testimonial-prev" type="button" aria-label="Depoimento anterior">‹</button>
        <div class="testimonial-track">
          {[1, 2, 3, 4, 5, 6].map((item) => (
            <figure>
              <img src={`/images/dep/sequencia/depoimento-${item}.jpg`} alt={`Depoimento ${item} da Jornada do Autoamor`} loading="lazy" />
            </figure>
          ))}
        </div>
        <button class="testimonial-arrow testimonial-next" type="button" aria-label="Próximo depoimento">›</button>
      </div>
    </section>

    <section class="section mirror-section">
      <div class="wrap center narrow">
        <h2 class="yellow-title">Você se reconhece em alguma dessas frases?</h2>
      </div>
      <div class="wrap quote-list">
        {mirrorQuotes.map((quote) => <blockquote>“{quote}”</blockquote>)}
      </div>
      <div class="wrap center narrow">
        <p class="recognition">Se alguma dessas frases pareceu familiar… <span>você está no lugar certo.</span></p>
        <div class="origin-highlight">
          <h3>Não começou em ti, mas precisa terminar em ti.</h3>
        </div>
      </div>
    </section>

    <section class="section reveal-section">
      <div class="wrap narrow center">
        <h2>Porque <span class="yellow-word">A Jornada do Autoamor é diferente</span> de tudo que você já tentou?</h2>
        <div class="reveal-list">
          <p>Você faz <span class="yellow-word">terapia</span> há anos e continua andando em círculos…</p>
          <p>Toma <span class="yellow-word">medicamento</span>, mascara a dor, mas continua sentindo um <span class="yellow-word">vazio</span> da alma…</p>
          <p>Você <span class="yellow-word">reza</span>, reza, reza e sua realidade não muda…</p>
          <p>Você lê <span class="yellow-word">livros</span>, mas não consegue colocar em prática…</p>
          <p>Você faz <span class="yellow-word">atividade física</span>, mas continua brigando com o espelho…</p>
        </div>
        <p class="lead">Assim como você, clientes chegam até mim todos os dias e falam “estou cansada, não aguento mais”. E após minhas intervenções, dizem:</p>
        <blockquote class="big-quote">“Isso é diferente de tudo que eu já fiz. Eu nunca tinha visto por esse caminho.”</blockquote>
      </div>
    </section>

    <section class="section post-lar-testimonials reveal-testimonials" aria-label="Mais depoimentos de alunas">
      <div class="wrap center narrow">
        <h2 class="testimonial-heading">O que quem participa compartilha...</h2>
      </div>
      <div class="testimonial-carousel reveal-grid-carousel" data-carousel>
        <button class="testimonial-arrow testimonial-prev" type="button" aria-label="Depoimento anterior">‹</button>
        <div class="testimonial-track">
          {[6, 1, 2, 3, 4, 5].map((item) => (
            <figure>
              <img src={`/images/dep/reveal/depoimento-${item}.jpg`} alt={`Depoimento ${item} sobre a Jornada do Autoamor`} loading="lazy" />
            </figure>
          ))}
        </div>
        <button class="testimonial-arrow testimonial-next" type="button" aria-label="Próximo depoimento">›</button>
      </div>
      <div class="wrap center narrow">
        <p class="testimonial-closing">O próximo depoimento pode ser o seu!</p>
      </div>
    </section>

    <section class="section bia-section">
      <div class="wrap bia-grid">
        <img src="/images/bia-quem-e.jpg" alt="Bia Munareto" loading="lazy" />
        <div>
          <h2>Bia Munareto não ensina o que estudou. Ela ensina o que viveu.</h2>
          <p>Psicóloga, terapeuta integrativa e mulher tântrica, Bia Munareto fundou a Jornada do Autoamor depois de ter vivido, em si mesma, o padrão que hoje transforma em outras.</p>
          <p>Aos 20 anos: bem-sucedida por fora, vazia por dentro. Corpo desconectado. Libido zerada. Existindo para os outros no automático. Sem conseguir nomear o que estava errado.</p>
          <blockquote>“Onde está o seu maior nó, está o seu maior propósito.”</blockquote>
          <p>O que ela mais envergonhava, ela transformou no que a tornaria singular.</p>
          <p>Em mais de 9 anos de atuação profissional, Bia tornou-se referência na intersecção entre psicologia, corpo e espiritualidade feminina. Com formação em Tantra, Constelação Familiar Sistêmica e Xamânica, Hipnose Ericksoniana, PNL, Neurociência e Reiki — e autora do livro A Jornada do Autoamor.</p>
          <p>Ela não fala do topo de uma montanha. Ela fala do meio do caminho com a autoridade de quem já atravessou o que está pedindo para você atravessar.</p>
          <strong>Ela não ensina o que sabe. Ela ensina o que é.</strong>
        </div>
      </div>
      <div class="wrap credentials">+200 mulheres ativas na Comunidade · +100 clientes em Mentorias · +500 livros vendidos · 9 anos de mercado digital · Instituto Autoamor fundado</div>
    </section>

    <section class="section testimonials dark">
      <div class="wrap center narrow">
        <p class="kicker">Transformação</p>
        <h2>O que as mulheres da Comunidade dizem</h2>
      </div>
      <div class="wrap testimonial-grid proof-shots readable-sequence-grid">
        {officialTestimonialsOne.map((image, i) => (
          <article>
            <img src={image} alt={`Depoimento real ${i + 1} do site oficial da Bia Munareto`} loading="lazy" />
          </article>
        ))}
      </div>
    </section>

    <section class="section community-section" id="comunidade">
      <div class="wrap narrow center">
        <p class="kicker">O que é a Comunidade</p>
        <h2>A Comunidade Jornada do Autoamor não é um curso.</h2>
        <p class="lead">É um lugar seguro onde você será acompanhada semanalmente por Bia e equipe. Com encontros ao vivo semanais, trilhas de aulas e meditações gravadas para você iniciar hoje mesmo.</p>
        <p class="lead">Um lugar que une ciência e espiritualidade para despertar o seu Autoamor, Autoestima e Autoconfiança. Um caminho individual, mas também coletivo.</p>
      </div>
      <div class="wrap pillar-grid">
        <article><h3>Ciência</h3><p>Psicologia, corpo, neurociência e práticas terapêuticas para transformar padrões com clareza.</p></article>
        <article><h3>Espiritualidade</h3><p>Rituais, meditações, mantras e práticas espirituais integradas ao cotidiano real.</p></article>
        <article><h3>Irmandade</h3><p>Uma comunidade para compartilhar a jornada com mulheres que entendem o que você vive.</p></article>
      </div>
    </section>

    <section class="section inside-section">
      <div class="wrap center narrow inclusions-intro">
        <h2>O que esta incluso na sua assinatura</h2>
        <p class="lead">Torne-se uma mulher melhor agora e tenha acesso à única plataforma para desenvolver seu autoamor, a qualquer hora, e em qualquer lugar.</p>
      </div>
      <div class="wrap inclusions-image-card">
        <img src="/images/incluso/assinatura.jpg" alt="Plataforma da Jornada do Autoamor inclusa na assinatura" loading="lazy" />
      </div>
      <div class="wrap deliverable-showcase">
        <article class="deliverable-row">
          <div class="deliverable-copy">
            <span class="deliverable-number">01.</span>
            <h3>Trilhas de transformação</h3>
            <p>Acesse os caminhos Básico e Aprofundamento para purificar padrões, construir uma nova identidade e sustentar a mulher que você quer se tornar.</p>
            <div class="deliverable-tags"><span>Libertar</span><span>Assumir</span><span>Realizar</span></div>
          </div>
          <div class="deliverable-card">
            <strong>Básico + Aprofundamento</strong>
            <p>Conteúdos organizados para você caminhar com clareza, sem se perder em aulas soltas.</p>
          </div>
        </article>
        <article class="deliverable-row reverse">
          <div class="deliverable-copy">
            <span class="deliverable-number">02.</span>
            <h3>Encontros semanais ao vivo</h3>
            <p>Você não caminha sozinha. Toda semana existe acompanhamento, direcionamento e presença para transformar consciência em prática.</p>
            <div class="deliverable-tags"><span>Ao vivo</span><span>Constância</span><span>Suporte</span></div>
          </div>
          <div class="deliverable-card">
            <strong>Comunidade viva</strong>
            <p>Um espaço para elaborar, aprofundar e sustentar sua evolução com Bia e equipe.</p>
          </div>
        </article>
        <article class="deliverable-row">
          <div class="deliverable-copy">
            <span class="deliverable-number">03.</span>
            <h3>Imersão mensal com a Bia</h3>
            <p>Uma sexta por mês, das 19h às 22h, com práticas de tantra e bioenergética ao vivo — para o aprendizado descer da cabeça para o corpo.</p>
            <div class="deliverable-tags"><span>Tantra</span><span>Bioenergética</span><span>Experiência</span></div>
          </div>
          <div class="deliverable-card">
            <strong>Não é só conteúdo</strong>
            <p>É prática, corpo, presença e experiência guiada para integrar a transformação.</p>
          </div>
        </article>
        <article class="deliverable-row reverse">
          <div class="deliverable-copy">
            <span class="deliverable-number">04.</span>
            <h3>WhatsApp Irmãs de Alma</h3>
            <p>A irmandade que existe entre os módulos e as lives: um lugar para compartilhar a jornada com mulheres que entendem o que você vive.</p>
            <div class="deliverable-tags"><span>Irmandade</span><span>Troca</span><span>Pertencimento</span></div>
          </div>
          <div class="deliverable-card">
            <strong>Entre uma live e outra</strong>
            <p>Você permanece conectada à energia da Comunidade e ao movimento da sua transformação.</p>
          </div>
        </article>
        <article class="deliverable-row">
          <div class="deliverable-copy">
            <span class="deliverable-number">05.</span>
            <h3>Práticas, meditações e ferramentas</h3>
            <p>Mantras, meditações guiadas, caderno terapêutico, práticas espirituais e conteúdos para integrar autoamor, autoestima e autoconfiança no cotidiano.</p>
            <div class="deliverable-tags"><span>Meditações</span><span>Mantras</span><span>Caderno terapêutico</span></div>
          </div>
          <div class="deliverable-card">
            <strong>Acesso a qualquer hora</strong>
            <p>Para voltar para si mesma no seu tempo, no seu ritmo e de onde estiver.</p>
          </div>
        </article>
        <article class="deliverable-row reverse">
          <div class="deliverable-copy">
            <span class="deliverable-number">06.</span>
            <h3>TRIX Inspira</h3>
            <p>IA treinada por Bia, disponível 24h por dia, para te aconselhar e te direcionar na utilização de ervas e práticas espirituais.</p>
            <div class="deliverable-tags"><span>IA da Bia</span><span>24h por dia</span><span>Ervas e espiritualidade</span></div>
          </div>
          <div class="deliverable-card">
            <strong>Direcionamento espiritual no seu ritmo</strong>
            <p>Um apoio inteligente para consultar quando precisar de clareza, orientação e práticas alinhadas à Jornada.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="section testimonials light">
      <div class="wrap center narrow">
        <h2>Elas falam: “é o melhor investimento!”</h2>
      </div>
      <div class="wrap testimonial-grid proof-shots centered-proof-shots">
        {officialTestimonialsTwo.map((image, i) => (
          <article>
            <img src={image} alt={`Depoimento real ${i + 5} do site oficial da Bia Munareto`} loading="lazy" />
          </article>
        ))}
      </div>
    </section>

    <section class="section pricing-section" id="precos">
      <div class="wrap center narrow">
        <p class="kicker">Comece agora</p>
        <h2>a se tornar a mulher mais feliz que você conhece</h2>
      </div>

      <div class="wrap price-grid tiered-price-grid comparison-cards">
