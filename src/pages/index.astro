---
import Layout from "../layouts/Layout.astro";
import content from "../data/content.json";

const { brand, cta, hero, kpis, manifesto, recognize, promise, method, curriculum, bonus, testimonials, offer, guarantee, faq, letter, footer } = content;
const fronts = ["Landing pages", "Tráfego", "Docs", "PDFs", "Relatórios", "Vendas"];
---

<Layout>
  <header class="war-nav">
    <a href="/" class="brand">{brand.name}</a>
    <nav>
      <a href="#sala">Centro de comando</a>
      <a href="#arsenal">Arsenal</a>
      <a href="#implantacao">Implantação</a>
      <a href={cta.link} class="nav-cta">Diagnóstico</a>
    </nav>
  </header>

  <main>
    <section class="war-hero">
      <div class="noise"></div>
      <div class="radar radar-a"></div>
      <div class="radar radar-b"></div>
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="kicker">{hero.eyebrow}</p>
          <h1>{hero.headline}</h1>
          <p class="lead">{hero.subheadline}</p>
          <div class="command-strip">
            <span>{hero.proofNumber}</span>
            <p>{hero.proofLabel}</p>
          </div>
          <div class="actions">
            <a href={cta.link} class="cta">{cta.text}</a>
            <p>{hero.microcopy}</p>
          </div>
        </div>

        <aside class="war-room-card hero-device" aria-label="Centro de comando operacional">
          <div class="screen-top">
            <span></span><span></span><span></span>
            <strong>COMMAND CENTER · ONLINE</strong>
          </div>
          <div class="hero-screen">
            <img src={hero.image} alt={hero.imageAlt} />
            <div class="floating-card card-one">
              <small>Próxima entrega</small>
              <strong>LP versionada</strong>
            </div>
            <div class="floating-card card-two">
              <small>Status</small>
              <strong>4 agentes ativos</strong>
            </div>
          </div>
          <div class="mission-log">
            <p><b>01</b> gargalos mapeados</p>
            <p><b>02</b> agentes com território</p>
            <p><b>03</b> entregas versionadas</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="stats-bar">
      {kpis.items.map((item) => (
        <div>
          <strong>{item.num}</strong>
          <span>{item.label}</span>
        </div>
      ))}
    </section>

    <section class="briefing" id="sala">
      <div class="section-label">CENTRO DE COMANDO</div>
      <div class="briefing-grid">
        <h2>{manifesto.title}</h2>
        <div>
          {manifesto.paragraphs.map((p) => <p>{p}</p>)}
          <p class="big-question">{manifesto.question}</p>
        </div>
      </div>
    </section>

    <section class="doctrine">
      <div class="doctrine-art">
        <img src={content.founder.image} alt={content.founder.imageAlt} />
      </div>
      <div class="doctrine-copy">
        <span>{content.founder.eyebrow}</span>
        <h2>{content.founder.name}</h2>
        {content.founder.bio.map((p) => <p>{p}</p>)}
      </div>
    </section>

    <section class="threats">
      <div class="section-head">
        <span>{recognize.eyebrow}</span>
        <h2>{recognize.title}</h2>
      </div>
      <div class="threat-grid">
        {recognize.items.map((item, i) => (
          <article>
            <small>RISCO 0{i + 1}</small>
            <h3>{item.top}</h3>
            <p>{item.bottom}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="arsenal" id="arsenal">
      <div class="arsenal-copy">
        <span>{method.eyebrow}</span>
        <h2>{method.title}</h2>
        <p>{method.summary}</p>
      </div>
      <div class="arsenal-grid">
        {method.pillars.map((pillar, i) => (
          <article>
            <small>0{i + 1}</small>
            <h3>{pillar.name}</h3>
            <p>{pillar.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="outcomes">
      <div class="section-head">
        <span>{promise.eyebrow}</span>
        <h2>{promise.title}</h2>
      </div>
      <div class="outcome-list">
        {promise.items.map((item) => (
          <div>
            <strong>{item.verb}</strong>
            <p>{item.object}</p>
            <em>{item.reframe}</em>
          </div>
        ))}
      </div>
    </section>

    <section class="proof-stack">
      <div class="section-head">
        <span>{bonus.eyebrow}</span>
        <h2>{bonus.title}</h2>
      </div>
      <div class="bonus-grid">
        {bonus.items.map((item, i) => (
          <article>
            <small>ATIVO 0{i + 1}</small>
            <h3>{item.name}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="evidence">
      <div class="section-head">
        <span>{testimonials.eyebrow}</span>
        <h2>{testimonials.title}</h2>
      </div>
      <div class="evidence-grid">
        {testimonials.items.map((item) => (
          <article>
            <img src={item.image} alt={item.name} />
            <div>
              <small>{item.city}</small>
              <h3>{item.name}</h3>
              <p>{item.quote}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="implantacao" id="implantacao">
      <div class="terminal">
        <div class="terminal-head">DEPLOY OPERACIONAL · 30 DIAS</div>
        {curriculum.modules.map((mod, i) => (
          <div class="terminal-row">
            <span>SEMANA {i + 1}</span>
            <strong>{mod.name}</strong>
            <p>{mod.duration} · {mod.format}</p>
          </div>
        ))}
      </div>
      <div class="offer-panel" id="oferta">
        <span>{offer.eyebrow}</span>
        <h2>{offer.title}</h2>
        <ul>
          {offer.includes.map((item) => <li>{item}</li>)}
        </ul>
        <a href={cta.link} class="cta">{cta.text}</a>
      </div>
    </section>

    <section class="guarantee-faq">
      <div class="guarantee-card">
        <span>{guarantee.eyebrow}</span>
        <h2>{guarantee.title}</h2>
        <p>{guarantee.text}</p>
        <p>{guarantee.comfort}</p>
      </div>
      <div class="faq-list">
        <span>{faq.eyebrow}</span>
        <h2>{faq.title}</h2>
        {faq.items.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="final-call">
      {letter.paragraphs.map((p) => <p>{p}</p>)}
      <a href={cta.link} class="cta">Quero montar meu centro de comando</a>
    </section>
  </main>

  <footer class="footer">
    <strong>{brand.name}</strong>
    <div>
      {footer.links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
  </footer>
</Layout>
